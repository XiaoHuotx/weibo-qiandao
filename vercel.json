{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "runtime": "edge"
    }
  },
  "crons": [
    {
      "path": "/api/weibo",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/weibo",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/weibo",
      "schedule": "0 8 * * *"
    }
  ],
  "routes": [
    {
      "src": "/api/weibo",
      "dest": "/api/weibo.js"
    }
  ]
}
